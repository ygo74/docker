{
  "annotations": { "list": [] },
  "description": "Redis Cluster monitoring via OpenTelemetry redis receiver",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "🔴 Cluster Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "redis_clients_connected{service_name=\"redis-cluster\"}",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Commands Processed (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Uptime (hours)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 24 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["last"] },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "redis_uptime_seconds_total{service_name=\"redis-cluster\"} / 3600",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "🧠 Memory",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "title": "Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{service_name=\"redis-cluster\"}",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Memory Peak",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "redis_memory_peak_bytes{service_name=\"redis-cluster\"}",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Memory RSS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "redis_memory_rss_bytes{service_name=\"redis-cluster\"}",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "⚡ CPU",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "title": "CPU Time — System (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_cpu_time_seconds_total{state=\"sys\", service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "CPU Time — User (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_cpu_time{state=\"user\", service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "🌐 Network",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "title": "Network Input (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Network Output (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_net_output_bytes_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "🎯 Cache Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },
    {
      "title": "Cache Hit Ratio (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["last"] }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{service_name=\"redis-cluster\"}[$__rate_interval]) / (rate(redis_keyspace_hits_total{service_name=\"redis-cluster\"}[$__rate_interval]) + rate(redis_keyspace_misses_total{service_name=\"redis-cluster\"}[$__rate_interval]))",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Keyspace Hits vs Misses (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "hits — {{server_address}}:{{server_port}}"
        },
        {
          "expr": "rate(redis_keyspace_misses_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "misses — {{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Expired & Evicted Keys (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_keys_expired_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "expired — {{server_address}}:{{server_port}}"
        },
        {
          "expr": "rate(redis_keys_evicted_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "evicted — {{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "🗃️ Keyspace",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "collapsed": false
    },
    {
      "title": "Total Keys per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (server_address, server_port) (redis_db_keys{service_name=\"redis-cluster\"})",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Keys with TTL per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (server_address, server_port) (redis_db_expires{service_name=\"redis-cluster\"})",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "🔗 Connections & Replication",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "collapsed": false
    },
    {
      "title": "Total Connections Received (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_connections_received_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    },
    {
      "title": "Rejected Connections (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(redis_connections_rejected_total{service_name=\"redis-cluster\"}[$__rate_interval])",
          "legendFormat": "{{server_address}}:{{server_port}}"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["redis", "opentelemetry", "cluster"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Redis Cluster — OpenTelemetry",
  "uid": "redis-cluster-otel",
  "version": 1
}
